# Required
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Error Monitoring (Sentry)
VITE_SENTRY_DSN=                         # Public DSN from sentry.io/settings/projects/<project>/keys/
VITE_SENTRY_RELEASE=                     # Optional: commit SHA or version tag (e.g. git rev-parse HEAD)

# Sentry Build-time (source map upload) — set in CI secrets, NOT committed
# Create a token at: https://sentry.io/settings/auth-tokens/ with project:releases + org:read
SENTRY_AUTH_TOKEN=
SENTRY_ORG=                              # e.g. my-org
SENTRY_PROJECT=                          # e.g. smartstudy-ai

# Analytics
VITE_POSTHOG_KEY=

# Payments
VITE_STRIPE_PUBLISHABLE_KEY=

# App URL
VITE_APP_URL=http://localhost:8080

# Server-side AI secret
# Do not put this in the Vite client env for production. Set it in Supabase Edge Functions instead:
# supabase secrets set GROQ_API_KEY=your_key
GROQ_API_KEY=
